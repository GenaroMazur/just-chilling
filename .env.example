# Just Chilling API - Environment Configuration
# This file serves as a template for the .env file. 
# Copy this to .env and adjust the values accordingly.

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
# Node environment: development, production
NODE_ENV=development

# TCP Port for the server to listen on
TCP_PORT=8080

# Logging level: error, warn, info, debug, verbose
LOG_LEVEL=info


# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# Supported types: sqlite, postgres, mysql, mariadb, oracle, mssql
DB_TYPE=sqlite

# Database name or path (for SQLite)
DB_DATABASE=database.sqlite

# Sync database schema with entities (Use FALSE in production)
DB_SYNCHRONIZE=false

# Log database queries
DB_LOGGING=false

# Connection details for non-sqlite databases
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=secret


# ==============================================================================
# SECURITY & AUTHENTICATION
# ==============================================================================
# Secret key for JWT signing (Keep this very secure in production!)
# Generate with: openssl rand -base64 32
JWT_SECRET=change_this_to_a_secure_random_value

# Password encryption level (argon2)
# low:    Fast, low resource usage (Development/Testing)
# medium: Standard security/performance balance (Staging/Production)
# high:   Maximum security, high memory/CPU usage (Critical Production)
PASSWORD_ENCRYPT_LEVEL=medium


# ==============================================================================
# INITIAL SEED DATA
# ==============================================================================
# Initial admin user credentials (created on first run if no admin exists)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin
INITIAL_ADMIN_EMAIL=admin@domain.com
